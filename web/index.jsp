<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Student Registration Form</title>
</head>
<body>

    <h2>Student Registration Form</h2>

    <form action="page" method="post">
        Name: <input type="text" name="name"><br><br>
        Age: <input type="text" name="age"><br><br>
        Course: <input type="text" name="course"><br><br>
        ABC ID: <input type="text" name="abcid"><br><br>
        Mother Name: <input type="text" name="mothername"><br><br>
        Father Name: <input type="text" name="fathername"><br><br>
        Applicant Full Name in Marathi:
        <input type="text" name="applicantmarathi"><br><br>

        <input type="submit" value="Submit">
    </form>

</body>
</html>